{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lean Time-Horizon task metadata",
  "type": "object",
  "required": [
    "task_id",
    "title",
    "split",
    "family",
    "domain",
    "source_type",
    "human_time_bucket",
    "human_minutes_p50",
    "human_minutes_p90",
    "human_estimate_confidence",
    "skills",
    "scaffolds",
    "expected_failure_modes",
    "scaffold_sensitivity",
    "qa_status",
    "acceptance_status",
    "difficulty_review_status",
    "difficulty_review_notes",
    "public_files",
    "axiom_audit_declarations",
    "extra_forbidden",
    "timeout_seconds"
  ],
  "properties": {
    "task_id": {"type": "string"},
    "title": {"type": "string"},
    "split": {"enum": ["dev", "test", "candidates"]},
    "family": {"type": "string"},
    "domain": {"type": "string"},
    "source_type": {"type": "string"},
    "human_time_bucket": {"enum": ["T0", "T1", "T2", "T3", "T4"]},
    "human_minutes_p50": {"type": "integer", "minimum": 1},
    "human_minutes_p90": {"type": "integer", "minimum": 1},
    "human_estimate_confidence": {"type": "string"},
    "skills": {"type": "array", "items": {"type": "string"}},
    "scaffolds": {"type": "array", "items": {"enum": ["one-shot", "lookup", "lookup_unlimited"]}},
    "expected_failure_modes": {"type": "array", "items": {"type": "string"}},
    "scaffold_sensitivity": {"type": "string"},
    "qa_status": {"type": "string"},
    "acceptance_status": {
      "enum": [
        "accepted_v0",
        "calibration_only",
        "candidate_review_pending",
        "candidate_not_accepted",
        "rejected_too_easy",
        "rejected_invalid",
        "rejected_duplicate",
        "rejected_grader_weak"
      ]
    },
    "difficulty_review_status": {"type": "string"},
    "difficulty_review_notes": {"type": "string"},
    "public_files": {"type": "array", "items": {"type": "string"}},
    "submission_file": {"type": "string"},
    "entry_file": {"type": "string"},
    "diagnostic_value": {"type": "string"},
    "frontier_model_one_shot_likelihood": {"type": "string"},
    "axiom_audit_declarations": {"type": "array", "items": {"type": "string"}},
    "extra_forbidden": {"type": "array", "items": {"type": "string"}},
    "timeout_seconds": {"type": "integer", "minimum": 1}
  }
}
